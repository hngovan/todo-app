{
  "name": "todo-app-root",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter \"./frontend\" dev & pnpm --filter \"./backend\" start:dev",
    "build": "pnpm --filter \"./frontend\" build && pnpm --filter \"./backend\" build",
    "lint": "pnpm --filter \"./frontend\" lint & pnpm --filter \"./backend\" lint",
    "format": "pnpm --filter \"./frontend\" format & pnpm --filter \"./backend\" format",
    "env:setup": "shx cp -n .env.example .env && pnpm -r env:setup",
    "env:clean": "shx rm -f .env && pnpm -r env:clean",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "shx": "^0.4.0",
    "typescript": "^5.6.0"
  }
}
